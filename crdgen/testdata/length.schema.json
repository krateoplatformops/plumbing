{
  "title": "Hello Length Example",
  "type": "object",
  "properties": {
    "username": {
      "type": "string",
      "description": "User name with bounded length",
      "minLength": 3,
      "maxLength": 20
    },
    "pin": {
      "type": "string",
      "description": "Fixed length PIN",
      "minLength": 4,
      "maxLength": 4
    },
    "bio": {
      "type": "string",
      "description": "Optional short biography",
      "maxLength": 160
    },
    "profile": {
      "type": "object",
      "properties": {
        "nickname": {
          "type": "string",
          "description": "Public nickname",
          "minLength": 1,
          "maxLength": 30
        }
      }
    }
  },
  "required": [
    "username",
    "pin"
  ]
}
